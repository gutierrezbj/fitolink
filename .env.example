# === API ===
NODE_ENV=development
PORT=4040
API_URL=http://localhost:4040

# === MongoDB ===
MONGODB_URI=mongodb://localhost:6040/fitolink

# === Auth ===
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Copernicus Data Space ===
COPERNICUS_CLIENT_ID=your-copernicus-client-id
COPERNICUS_CLIENT_SECRET=your-copernicus-client-secret

# === Email (Resend) ===
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=alertas@fitolink.srs.es

# === Frontend ===
VITE_API_URL=http://localhost:4040
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_APP_NAME=FitoLink
VITE_SHOW_DEMO=true
