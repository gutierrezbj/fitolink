# MongoDB
MONGODB_URI=mongodb://localhost:27017/fitolink

# Copernicus Data Space Ecosystem (CDSE)
# Create credentials at: https://dataspace.copernicus.eu/
# Used for BOTH openEO cloud processing AND OData download fallback
COPERNICUS_CLIENT_ID=your_cdse_client_id
COPERNICUS_CLIENT_SECRET=your_cdse_client_secret

# openEO cloud processing (Sprint GEE)
# Set to false to force legacy OData download (not recommended — much slower)
USE_OPENEO=true

# OData download fallback — temp directory for Sentinel-2 SAFE ZIP files
# Only used when USE_OPENEO=false or openEO call fails
DOWNLOAD_DIR=/tmp/fitolink-downloads
